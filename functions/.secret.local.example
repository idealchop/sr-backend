# Copy to `.secret.local` for Firebase Functions emulator (NOT deployed).
#   cp .secret.local.example .secret.local
#
# The emulator loads secrets bound in `src/index.ts` from Secret Manager unless
# overridden here. Use placeholder values for local-only testing.
#
# IMPORTANT: firebase-tools parseStrict only allows keys matching ^[A-Z_][A-Z0-9_]*$
# Do NOT put hyphenated Secret Manager IDs here (e.g. smartrefill-firebase-google-maps-api-key).
# For Maps, use SMARTREFILL_GOOGLE_MAPS_SERVER_API_KEY; the hyphenated browser secret
# is fetched from Secret Manager when ADC is available.
#
# See: frontend/docs/community-dispatch-test-summary.md

DOCS_ADMIN_TOKEN=local-docs-admin-token
SMARTREFILL_BREVO_API_KEY=local-brevo-placeholder
GEMINI_API_KEY=local-gemini-placeholder
SMARTREFILL_GOOGLE_MAPS_SERVER_API_KEY=local-maps-server-placeholder
META_COMMUNITY_VERIFY_TOKEN=local-dev-verify
META_COMMUNITY_PAGE_ACCESS_TOKEN=
META_COMMUNITY_PAGE_ID=local-test-page
META_COMMUNITY_APP_SECRET=local-dev-app-secret
PAYMONGO_SECRET_KEY=local-paymongo-secret
PAYMONGO_WEBHOOK_SECRET=local-paymongo-webhook
