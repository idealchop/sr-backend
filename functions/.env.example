# Copy to `.env` for local emulator / `npm run serve` only.
# Never deploy `.env` — production uses Secret Manager + Cloud Run env (see backend docs).

# Local dev mode (must NOT be set on deployed Cloud Functions)
SMARTREFILL_ENV_DEV=true

# Public app origin for invite/verification links in dev (prod always uses https://smartrefill.io)
APP_BASE_URL=http://localhost:3000

# Firestore database id
SMARTREFILL_FIRESTORE_DB=riverdb

# Firebase Admin (local emulator or explicit service account)
SMARTREFILL_FIREBASE_PROJECT_ID=
SMARTREFILL_FIREBASE_CLIENT_EMAIL=
SMARTREFILL_FIREBASE_PRIVATE_KEY=
SMARTREFILL_FIREBASE_STORAGE_BUCKET=
SMARTREFILL_FIREBASE_API_KEY=

# Brevo transactional email (local only — prod: Secret Manager SMARTREFILL_BREVO_API_KEY)
SMARTREFILL_BREVO_API_KEY=

# Google Gemini (River AI tools, scans, support chat — prod: Secret Manager GEMINI_API_KEY)
# Create at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-3.1-flash-lite — one release behind gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Google Maps Geocoding (community dispatch CP-07, customer import)
# Production server key (Application restrictions: None, Geocoding API enabled):
#   firebase functions:secrets:set SMARTREFILL_GOOGLE_MAPS_SERVER_API_KEY
GOOGLE_MAPS_SERVER_API_KEY=
# Legacy browser key — frontend only (HTTP referrers); do not use for server geocoding.
# GOOGLE_MAPS_API_KEY=

# Portal/customer transactional SMS (requires SMARTREFILL_BREVO_API_KEY; emulator logs only)
# Customer transaction SMS (NT-36). Set true in production once Brevo SMS is configured.
# SMARTREFILL_SMS_ENABLED=true

# Meta community Page Messenger webhook (CP-01 / CP-02 / CP-27)
# Local testing: use any string; leave PAGE_ACCESS_TOKEN empty so no real Messenger sends.
META_COMMUNITY_VERIFY_TOKEN=local-dev-verify
# META_COMMUNITY_PAGE_ACCESS_TOKEN=
# META_COMMUNITY_PAGE_ID=local-test-page
# App secret from Meta App → Settings → Basic (CP-27 signature). Optional locally.
# META_COMMUNITY_APP_SECRET=

# Emulator secret overrides (required when a bound secret is missing in Secret Manager):
#   cp .secret.local.example .secret.local
# Firebase loads `.secret.local` instead of calling Secret Manager for those keys.

# Optional
SUPPORT_EMAIL=support@riverph.com
APP_CHECK_ENFORCE=false
# Swagger / Postman admin token (local emulator only — production: Secret Manager DOCS_ADMIN_TOKEN)
DOCS_ADMIN_TOKEN=
