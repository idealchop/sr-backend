{
  "name": "smartrefill-v3-api",
  "version": "1.0.0",
  "description": "SmartRefill V3 Lean API Gateway",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:generate": "ts-node src/docs/postman-generator.ts",
    "serve": "ts-node-dev --respawn --transpile-only src/index.ts",
    "serve:local": "ts-node-dev --respawn --transpile-only src/local-server.ts",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions:v3-api",
    "deploy:full": "npm run build && npm run test && npm run test:bdd && npm run lint && npm run deploy",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:bdd": "playwright test",
    "test:bdd:local": "cd .. && npm run test:bdd:local",
    "test:all": "npm run test && npm run test:bdd",
    "test:watch": "vitest",
    "sync:subscription-plans": "ts-node src/scripts/sync-subscription-plans.ts",
    "audit:river-ai-knowledge": "ts-node src/scripts/audit-river-ai-knowledge.ts",
    "community:messenger:preview": "ts-node src/scripts/community-messenger-preview.ts",
    "community:messenger:simulate": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 ts-node src/scripts/community-messenger-simulate.ts",
    "test:community": "vitest run src/__tests__/unit/services/meta src/__tests__/unit/handlers/meta-community-webhook-handler.unit.test.ts src/__tests__/unit/services/notifications/community-dispatch-offer-push-service.unit.test.ts src/__tests__/integration/community-meta-webhook.integration.test.ts",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@getbrevo/brevo": "^3.0.1",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "supertest": "^6.3.4",
    "swagger-jsdoc": "^6.2.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "private": true
}
